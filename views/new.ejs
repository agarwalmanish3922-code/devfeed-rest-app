<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Post · DevFeed</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
  <a class="nav-brand" href="/posts">Dev<span>Feed</span></a>
  <span class="nav-pill">Community</span>
</nav>

<div class="container">
  <a class="back-link" href="/posts">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Back to feed
  </a>

  <div class="form-card">
    <h2 class="form-title">Create a new post</h2>

    <form action="/posts" method="post">
      <div class="form-group">
        <label class="form-label" for="username">Username</label>
        <input class="form-input" type="text" id="username" name="username" placeholder="e.g. manish_dev" autocomplete="off" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="content">Your post</label>
        <textarea class="form-textarea" id="content" name="content" placeholder="Share a thought, a code tip, a win..." required></textarea>
      </div>
      <div class="form-footer">
        <button class="btn btn-primary" type="submit">Publish post</button>
        <a class="btn btn-ghost" href="/posts">Cancel</a>
      </div>
    </form>
  </div>
</div>

</body>
</html>
