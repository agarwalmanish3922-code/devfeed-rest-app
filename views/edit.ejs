<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Post · DevFeed</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
  <a class="nav-brand" href="/posts">Dev<span>Feed</span></a>
  <span class="nav-pill">Community</span>
</nav>

<div class="container">
  <a class="back-link" href="/posts/<%= post.id %>">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Back to post
  </a>

  <div class="form-card">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.5rem;">
      <div class="avatar"><%= post.username.slice(0,2).toUpperCase() %></div>
      <div>
        <div class="form-title" style="margin:0">Edit post</div>
        <span style="color:var(--text-secondary); font-size:0.85rem;">@<%= post.username %></span>
      </div>
    </div>

    <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
      <div class="form-group">
        <label class="form-label" for="content">Update your post</label>
        <textarea class="form-textarea" id="content" name="content" rows="6" required><%= post.content %></textarea>
      </div>
      <div class="form-footer">
        <button class="btn btn-primary" type="submit">Save changes</button>
        <a class="btn btn-ghost" href="/posts/<%= post.id %>">Cancel</a>
      </div>
    </form>
  </div>
</div>

</body>
</html>
